# Copy to .env (which is git-ignored) and fill in real values.

# Shared secret between the Quack server and the Toolbox source config.
# Must match the regex ^[A-Za-z0-9_-]{8,}$ (enforced by the duckdb-quack source).
QUACK_TOKEN=analytics-team-token-CHANGE-ME

# Only needed for the LangGraph demo (`docker compose --profile agent run langgraph`).
ANTHROPIC_API_KEY=sk-ant-...
