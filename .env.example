# Copy to .env (which is git-ignored) and fill in real values.

# Shared secrets between each Quack server and the matching Toolbox
# source config (tools.yaml). One token per server so a leaked
# credential for one source never grants access to another.
# Each must match the regex ^[A-Za-z0-9_-]{8,}$ (enforced by the
# duckdb-quack source).
QUACK_TOKEN_SALES=sales-token-CHANGE-ME
QUACK_TOKEN_INVENTORY=inventory-token-CHANGE-ME
QUACK_TOKEN_ENGINEERED=engineered-token-CHANGE-ME

# Only needed for the LangGraph demo (`docker compose --profile agent run langgraph`).
ANTHROPIC_API_KEY=sk-ant-...

# Where the mcp-toolbox-duckdb fork (branch feat/duckdb-quack) is
# checked out. Defaults to a sibling directory of this repo:
#   git clone -b feat/duckdb-quack https://github.com/mitja/mcp-toolbox-duckdb ../mcp-toolbox-duckdb
#TOOLBOX_SRC=../mcp-toolbox-duckdb

# Superset admin login (bi profile). Defaults to admin/admin.
#SUPERSET_ADMIN_USERNAME=admin
#SUPERSET_ADMIN_PASSWORD=admin
#SUPERSET_SECRET_KEY=demo-not-a-secret-rotate-me-before-prod
